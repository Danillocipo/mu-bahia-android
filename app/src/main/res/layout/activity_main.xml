<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:fillViewport="true">

    <RelativeLayout
        android:id="@+id/contentRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MU BAHIA"
                android:textColor="#e94560"
                android:textSize="40sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:shadowColor="#e94560"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="20" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Android Launcher"
                android:textColor="#0f3460"
                android:textSize="14sp"
                android:letterSpacing="0.25"
                android:layout_marginBottom="32dp" />

            <!-- Progress -->
            <androidx.cardview.widget.CardView
                android:id="@+id/progressCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#16213e"
                app:cardElevation="8dp"
                app:contentPadding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressTint="#e94560"
                        android:progressBackgroundTint="#0f3460"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:max="100"
                        android:progress="0" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="..."
                        android:textColor="#8899aa"
                        android:textSize="14sp"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:id="@+id/percentText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="#e94560"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Setup card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/setupCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#16213e"
                app:cardElevation="8dp"
                app:contentPadding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/infoText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bem-vindo!"
                        android:textColor="#8899aa"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginBottom="24dp" />

                    <Button
                        android:id="@+id/downloadBtn"
                        android:layout_width="280dp"
                        android:layout_height="56dp"
                        android:text="BAIXAR MU BAHIA"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:background="@drawable/btn_primary" />

                    <Button
                        android:id="@+id/installWinlatorBtn"
                        android:layout_width="280dp"
                        android:layout_height="56dp"
                        android:text="INSTALAR WINLATOR"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:visibility="gone"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/btn_primary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Done card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/doneCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#16213e"
                app:cardElevation="8dp"
                app:contentPadding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tudo pronto!"
                        android:textColor="#e94560"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/doneInfoText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#8899aa"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="24dp" />

                    <Button
                        android:id="@+id/openWinlatorBtn"
                        android:layout_width="280dp"
                        android:layout_height="56dp"
                        android:text="ABRIR WINLATOR"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:background="@drawable/btn_primary" />

                    <Button
                        android:id="@+id/deleteBtn"
                        android:layout_width="280dp"
                        android:layout_height="48dp"
                        android:text="Apagar arquivos"
                        android:textSize="13sp"
                        android:textColor="#ff4444"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/btn_secondary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Baixa os arquivos do Mu Bahia e instala o Winlator"
                android:textColor="#334466"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="24dp" />
        </LinearLayout>
    </RelativeLayout>
</ScrollView>
